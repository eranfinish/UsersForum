pipeline {
  agent any

  environment {
    REGISTRY   = 'k3d-myregistry.localhost:5000'
    IMAGE_NAME = 'users-forum-service'
    IMAGE_TAG  = "${BUILD_NUMBER}"
    FULL_IMAGE = "${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
    KUBECONFIG = credentials('kubeconfig')
  }

  stages {

    // ━━━━━━━━━━━━━━━━━━━━━━━━
    // Stage 1: משיכת הקוד
    // ━━━━━━━━━━━━━━━━━━━━━━━━
    stage('Checkout') {
      steps {
        checkout scm
        sh 'echo "✅ Code checked out: $(git log --oneline -1)"'
      }
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━
    // Stage 2: Build & Test
    // ━━━━━━━━━━━━━━━━━━━━━━━━
    stage('Build & Test') {
      steps {
        sh 'dotnet restore UsersForumService.sln'
        sh 'dotnet build UsersForumService.sln -c Release --no-restore'
        sh 'dotnet test UsersForumService.sln --no-build -c Release'
      }
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━
    // Stage 3: Build Docker Image
    // ━━━━━━━━━━━━━━━━━━━━━━━━
    stage('Build Docker Image') {
      steps {
        script {
          def appVersion = sh(script: "grep -oP '(?<=<Version>)[^<]+' UsersForumService/UsersForumService.csproj || echo '1.0.0'", returnStdout: true).trim()
          env.VERSION_TAG = "${appVersion}-${BUILD_NUMBER}"
        }
        sh """
          docker build \
            -t ${FULL_IMAGE} \
            -t ${REGISTRY}/${IMAGE_NAME}:${env.VERSION_TAG} \
            .
          echo "📦 Image size: \$(docker image inspect ${FULL_IMAGE} --format='{{.Size}}' | numfmt --to=iec)"
        """
      }
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━
    // Stage 4: Push לRegistry
    // ━━━━━━━━━━━━━━━━━━━━━━━━
    stage('Push Image') {
      steps {
        sh """
          docker push ${FULL_IMAGE}
          docker push ${REGISTRY}/${IMAGE_NAME}:${env.VERSION_TAG}
          echo "✅ Pushed: ${FULL_IMAGE} and ${REGISTRY}/${IMAGE_NAME}:${env.VERSION_TAG}"
        """
      }
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━
    // Stage 5: Deploy לKubernetes
    // ━━━━━━━━━━━━━━━━━━━━━━━━
    stage('Deploy to K8s') {
      steps {
        sh """
          export KUBECONFIG=${KUBECONFIG}

          kubectl set image deployment/users-forum-service \
            users-forum-service=${FULL_IMAGE}

          kubectl rollout status deployment/users-forum-service \
            --timeout=120s

          echo "☸️ Deployed version: ${IMAGE_TAG}"
        """
      }
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━
    // Stage 6: Smoke Test
    // ━━━━━━━━━━━━━━━━━━━━━━━━
    stage('Smoke Test') {
      steps {
        sh """
          sleep 10

          curl -f http://localhost:8080/health \
            || (echo "❌ Smoke test failed!" && exit 1)

          echo "✅ Smoke test passed!"
        """
      }
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━
  // Post actions — מה קורה בכל מצב
  // ━━━━━━━━━━━━━━━━━━━━━━━━
  post {
    success {
      echo "🎉 Pipeline הצליח! Version: ${IMAGE_TAG}"
    }
    failure {
      echo "💥 Pipeline נכשל! מבצע rollback..."
      sh """
        export KUBECONFIG=${KUBECONFIG}
        kubectl rollout undo deployment/users-forum-service
        echo "↩️ Rollback בוצע!"
      """
    }
    always {
      sh 'docker image prune -f'
    }
  }
}
