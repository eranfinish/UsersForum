pipeline {
  agent any

  environment {
    PUSH_REGISTRY = 'host.docker.internal:5000'
    K8S_REGISTRY  = 'k3d-myregistry.localhost:5000'
    IMAGE_NAME    = 'users-forum-service'
    IMAGE_TAG     = "${BUILD_NUMBER}"
    FULL_IMAGE    = "${PUSH_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
    K8S_IMAGE     = "${K8S_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
    KUBECONFIG    = credentials('kubeconfig')
  }

  stages {

    // ━━━━━━━━━━━━━━━━━━━━━━━━
    // Stage 1: משיכת הקוד
    // ━━━━━━━━━━━━━━━━━━━━━━━━
    stage('Checkout') {
      steps {
        checkout scm
        sh 'echo "✅ Code checked out: $(git log --oneline -1)"'
      }
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━
    // Stage 2: Build Docker Image
    // ━━━━━━━━━━━━━━━━━━━━━━━━
    stage('Build Docker Image') {
      steps {
        script {
          def appVersion = sh(script: "grep -oP '(?<=<Version>)[^<]+' UsersForumService/UsersForumService.csproj || echo '1.0.0'", returnStdout: true).trim()
          env.VERSION_TAG = "${appVersion}-${BUILD_NUMBER}"
        }
        sh """
          docker build \
            -f UsersForumService/Dockerfile \
            -t ${FULL_IMAGE} \
            -t ${PUSH_REGISTRY}/${IMAGE_NAME}:${env.VERSION_TAG} \
            UsersForumService/
          echo "📦 Image size: \$(docker image inspect ${FULL_IMAGE} --format='{{.Size}}' | numfmt --to=iec)"
        """
      }
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━
    // Stage 4: Push לRegistry
    // ━━━━━━━━━━━━━━━━━━━━━━━━
    stage('Push Image') {
      steps {
        sh """
          docker push ${FULL_IMAGE}
          docker push ${PUSH_REGISTRY}/${IMAGE_NAME}:${env.VERSION_TAG}
          echo "✅ Pushed: ${FULL_IMAGE} and ${PUSH_REGISTRY}/${IMAGE_NAME}:${env.VERSION_TAG}"
        """
      }
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━
    // Stage 5: Deploy לKubernetes
    // ━━━━━━━━━━━━━━━━━━━━━━━━
    stage('Deploy to K8s') {
      steps {
        sh """
          export KUBECONFIG=${KUBECONFIG}

          kubectl set image deployment/users-forum-service \
            users-forum-service=${K8S_IMAGE} \
            -n users-forum-service

          kubectl rollout status deployment/users-forum-service \
            -n users-forum-service \
            --timeout=120s

          echo "☸️ Deployed version: ${IMAGE_TAG}"
        """
      }
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━
    // Stage 6: Smoke Test
    // ━━━━━━━━━━━━━━━━━━━━━━━━
    stage('Smoke Test') {
      steps {
        sh """
          sleep 5
          READY=\$(kubectl get deployment/users-forum-service -n users-forum-service -o jsonpath='{.status.readyReplicas}')
          if [ "\$READY" = "1" ]; then
            echo "✅ Smoke test passed! Pod is running."
          else
            echo "❌ Smoke test failed! readyReplicas=\$READY"
            exit 1
          fi
        """
      }
    }
  }

  // ━━━━━━━━━━━━━━━━━━━━━━━━
  // Post actions — מה קורה בכל מצב
  // ━━━━━━━━━━━━━━━━━━━━━━━━
  post {
    success {
      echo "🎉 Pipeline הצליח! Version: ${IMAGE_TAG}"
    }
    failure {
      echo "💥 Pipeline נכשל! מבצע rollback..."
      sh """
        export KUBECONFIG=${KUBECONFIG}
        kubectl rollout undo deployment/users-forum-service -n users-forum-service
        echo "↩️ Rollback בוצע!"
      """
    }
    always {
      sh 'docker image prune -f'
    }
  }
}
